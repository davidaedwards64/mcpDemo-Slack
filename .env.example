# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Session (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=

# Slack MCP token (Phase 1 fallback — not needed when Okta is configured)
SLACK_MCP_TOKEN=xoxp-...

# --- Phase 2: Okta OIDC (web app / confidential client) ---
OKTA_DOMAIN=                  # e.g. your-org.okta.com  (no https://)
OKTA_CLIENT_ID=               # Web app client_id
OKTA_CLIENT_SECRET=           # Web app client_secret
OKTA_REDIRECT_URI=http://localhost:8000/auth/callback

# --- Phase 2: Okta AI Agent workload (private key JWT client) ---
OKTA_AGENT_CLIENT_ID=         # AI Agent app client_id
OKTA_AGENT_PRIVATE_JWK=       # RSA private key as single-line JSON string

# --- Phase 2: Slack MCP Server resource indicator ---
OKTA_MCP_RESOURCE_INDICATOR=  # ORN of the Slack MCP Server object registered in Okta

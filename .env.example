# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Session (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=

# Slack MCP — OAuth user token for https://mcp.slack.com/mcp
# Requires a Slack app installed to your workspace with appropriate scopes.
# Use a user token (xoxp-...) for full read/write access.
SLACK_MCP_TOKEN=xoxp-...

# --- Phase 2: Okta for AI Agents ---
# OKTA_DOMAIN=                 # e.g. your-org.okta.com  (no https://)
# OKTA_CLIENT_ID=              # Agentic App client_id
# OKTA_CLIENT_SECRET=          # Agentic App client_secret
# OKTA_REDIRECT_URI=http://localhost:8000/auth/callback
# OKTA_AGENT_CLIENT_ID=        # AI Agent workload client_id
# OKTA_AGENT_PRIVATE_JWK=      # Agent RSA private key as JSON string (single line)
# OKTA_MCP_RESOURCE_INDICATOR= # ORN of the Slack MCP Server object in Okta
